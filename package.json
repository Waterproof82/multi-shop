{
  "name": "my-v0-project",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--use-system-ca next dev",
    "build": "tsc --noEmit && next build",
    "build:analyze": "ANALYZE=true pnpm build",
    "start": "next start",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --format stylish",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "sonar": "sonar-scanner",
    "start:electron": "electron electron/dist/main.js",
    "build:electron:prep": "tsc -p electron/tsconfig.json --noEmit && esbuild electron/main.ts --bundle --platform=node --target=node20 --external:electron --outfile=electron/dist/main.js && esbuild electron/preload.ts --bundle --platform=node --target=node20 --external:electron --outfile=electron/dist/preload.js",
    "build:electron:rebuild": "electron-rebuild",
    "build:electron": "pnpm build:electron:prep && pnpm build:electron:rebuild && electron-builder --win",
    "dev:electron": "cross-env NODE_ENV=development electron electron/dist/main.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1015.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@radix-ui/react-dialog": "1.1.20",
    "@radix-ui/react-dropdown-menu": "2.1.21",
    "@radix-ui/react-label": "2.1.12",
    "@radix-ui/react-select": "^2.3.4",
    "@radix-ui/react-slot": "1.3.0",
    "@radix-ui/react-toast": "1.2.20",
    "@sentry/nextjs": "^10.67.0",
    "@smithy/node-http-handler": "^4.4.14",
    "@supabase/supabase-js": "^2.110.7",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.3",
    "@zxing/browser": "^0.2.0",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "^7.0.3",
    "electron-updater": "^6.8.9",
    "framer-motion": "^11.15.0",
    "jose": "^6.1.3",
    "lucide-react": "^0.577.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "node-thermal-printer": "^4.6.0",
    "qrcode": "^1.5.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "recharts": "2.15.4",
    "tailwind-merge": "^3.3.1",
    "uuid": "^13.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@eslint/eslintrc": "^3.3.4",
    "@next/bundle-analyzer": "^16.2.2",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.1.9",
    "@types/node": "^22",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "baseline-browser-mapping": "2.10.9",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.5",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.21.0",
    "tw-animate-css": "1.3.3",
    "typescript": "^5"
  }
}
